{
	"schemaVersion": 1,
	"id": "smpcore",
	"version": "${version}",
	"name": "SMP Core",
	"description": "Server-side SMP rules, combat balance tweaks, and QOL features for Fabric 1.21.11.",
	"authors": [
		"SMP Core"
	],
	"contact": {
		"sources": "https://example.invalid/smpcore"
	},
	"license": "CC0-1.0",
	"icon": "assets/smpcore/icon.png",
	"environment": "*",
	"entrypoints": {
		"main": [
			"com.smpcore.liam.SmpCore"
		],
		"client": [
			"com.smpcore.liam.SmpCoreClient"
		],
		"fabric-datagen": [
			"com.smpcore.liam.SmpCoreDataGenerator"
		]
	},
	"mixins": [
		"smpcore.mixins.json",
		{
			"config": "smpcore.client.mixins.json",
			"environment": "client"
		}
	],
	"depends": {
		"fabricloader": ">=0.18.4",
		"minecraft": "~1.21.11",
		"java": ">=21",
		"fabric-api": "*"
	}
}
